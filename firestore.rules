rules_version = '2';

// Centro de Mando — un solo usuario, un solo documento (appdata/lifedash_v2).
// Solo el dueño autenticado con Google (este uid) puede leer/escribir sus datos.
// Todo lo demás queda denegado por defecto.
service cloud.firestore {
  match /databases/{database}/documents {
    match /appdata/{docId} {
      allow read, write: if request.auth != null
        && request.auth.uid == "vy1BtfYJTJcbuAPWlRRPA0OKsOJ3";
    }
  }
}
