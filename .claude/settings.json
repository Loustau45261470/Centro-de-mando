{
  "permissions": {
    "allow": [
      "WebFetch(domain:anthropic.skilljar.com)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/scripts/guard-sync-files.js\"",
            "statusMessage": "Guard: archivos de sync/reglas"
          }
        ]
      }
    ]
  }
}
